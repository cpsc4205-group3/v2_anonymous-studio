{
  "title": "Anonymous Studio",
  "uid": "anon-studio-jobs",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Jobs Created (functional metric)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(anon_jobs_created_total[5m])",
          "legendFormat": "jobs/s created"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 2,
      "title": "Job Queue Depth by Status (operational metric)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "anon_job_queue_depth",
          "legendFormat": "{{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 3,
      "title": "Job Completion Rate by Status",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(anon_jobs_status_total[5m])",
          "legendFormat": "{{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 4,
      "title": "Job Duration (p50 / p95 / p99)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(anon_job_duration_seconds_bucket[5m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(anon_job_duration_seconds_bucket[5m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(anon_job_duration_seconds_bucket[5m]))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 5,
      "title": "PII Entities Detected",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "x": 0, "y": 16, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "anon_entities_detected_total",
          "legendFormat": "Entities"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 6,
      "title": "Rows Processed",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "x": 6, "y": 16, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "anon_rows_processed_total",
          "legendFormat": "Rows"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 7,
      "title": "Scenarios Created",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "x": 12, "y": 16, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "anon_scenarios_created_total",
          "legendFormat": "Scenarios"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 8,
      "title": "Total Jobs Created",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "x": 18, "y": 16, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "anon_jobs_created_total",
          "legendFormat": "Jobs"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    }
  ]
}
